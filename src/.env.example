# ===== ETHEREUM SEPOLIA CONFIGURATION =====
# Blockchain RPC endpoint for Ethereum Sepolia testnet
# GET FROM: https://app.infura.io/ (free account) or https://alchemy.com/ (free account)
SEPOLIA_RPC_URL=

# Deployed SupplyChain.sol contract address on Sepolia
# GET FROM: After deploying SupplyChain.sol to Sepolia testnet
# DEPLOY VIA: Remix IDE (https://remix.ethereum.org) or Hardhat
CONTRACT_ADDRESS=

# ===== PINATA / IPFS CONFIGURATION =====
# Pinata API Key (free account)
# GET FROM: https://pinata.cloud/register > Dashboard > API Keys > "New Key"
PINATA_API_KEY=

# Pinata Secret API Key
# GET FROM: https://pinata.cloud > Dashboard > API Keys > same "New Key" page
PINATA_SECRET_API_KEY=

# ===== WALT.ID CONFIGURATION =====
# walt.id Wallet API endpoint (local docker or remote)
# DEFAULT: http://localhost:7001/wallet-api (if running locally)
# REMOTE: Use your docker-compose stack URL if running remotely
WALT_ID_API_URL=http://localhost:7001/wallet-api


# Walt.id Issuer & Verifier (Docker profile identity)
WALT_ISSUER_API_URL=http://localhost:7002
WALT_VERIFIER_API_URL=http://localhost:7003


# Application Database Configuration (PostgreSQL)
# Note: Walt.id uses its own PostgreSQL instance
APP_DB_HOST=app-postgres
APP_DB_NAME=diplomska_app
APP_DB_USERNAME=app_user
APP_DB_PASSWORD=app_password_secure
APP_POSTGRES_DB_PORT=5432

# Server Port
PORT=3000