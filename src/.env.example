# Local anvil
CHAIN_RPC_URL=http://anvil:8545
CHAIN_RPC_PUBLIC=http://127.0.0.1:8545
CHAIN_ID=31337
CHAIN_NAME=Anvil Local
# Avtomatski strežniški podpis TX na Anvil (privzeto true za CHAIN_ID=31337)
# false = vsaka TX prek MetaMask; true = strežnik podpiše (samo dev/demo)
CHAIN_AUTO_SIGN=false
CONTRACT_ADDRESS=[from deploy script]
ETHERSCAN_BASE_URL=[empty]

# Sepolia testnet
# CONTRACT_ADDRESS=
# CHAIN_RPC_URL=https://sepolia.infura.io/v3/...
# CHAIN_RPC_PUBLIC=
# CHAIN_ID=11155111
# CHAIN_NAME=Sepolia
# ETHERSCAN_BASE_URL=https://sepolia.etherscan.io

CONTRACT_ADDRESS=

PINATA_API_KEY=

PINATA_SECRET_API_KEY=

WALT_ID_API_URL=http://wallet-api:7001/wallet-api
WALT_ISSUER_API_URL=http://issuer-api:7002
WALT_VERIFIER_API_URL=http://verifier-api:7003

# Walt.id DID ob registraciji: key = did:key (eIDAS/OID4VC smer) | jwk = legacy
WALT_DID_METHOD=key
# did:key z jwk_jcs-pub — profil za OID4VCI/OID4VP (Walt.id POST .../dids/create/key?useJwkJcsPub=true)
WALT_DID_USE_JWK_JCS_PUB=true

# Format poverilnic: vc+sd-jwt (eIDAS 2.0 / EUDI SD-JWT VC, privzeto) | jwt_vc_json (legacy W3C)
WALT_CREDENTIAL_FORMAT=vc+sd-jwt

# Application Database 
APP_DB_ENGINE=postgres
APP_DB_HOST=app-postgres
APP_DB_NAME=diplomska_app
APP_DB_USERNAME=admin
APP_DB_PASSWORD=admin
APP_POSTGRES_DB_PORT=5432

# Server Port
PORT=3000

# ===== AI asistent (VC razlaga) — priporočeno: Groq (brezplačno) =====
# 1) Ustvari ključ: https://console.groq.com/keys (brez kreditne kartice)
# 2) Odkomentiraj in restart: docker compose restart app
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# Alternativa: Google Gemini — https://aistudio.google.com/apikey
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Alternativa: OpenAI (plačljivo)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Prisili ponudnika: groq | gemini | openai
# AI_PROVIDER=groq